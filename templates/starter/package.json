    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "jsdom": "^29.1.1",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
